# Active provider: "openrouter" or "gemini"
LLM_PROVIDER=openrouter
# OpenRouter - https://openrouter.ai/keys (primary provider)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Gemini - https://aistudio.google.com/apikey (fallback provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# LLM tuning
BATCH_SIZE=40
CONCURRENCY=3
