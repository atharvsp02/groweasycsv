# Active provider: "gemini" (default) or "openrouter"
LLM_PROVIDER=gemini
# Gemini - https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# OpenRouter - https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# LLM tuning
BATCH_SIZE=40
CONCURRENCY=3
